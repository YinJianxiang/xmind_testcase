{
  "mcpServers": {
    "lark-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "@larksuiteoapi/lark-mcp",
        "mcp",
        "-a",
        "${LARK_MCP_APP_ID}",
        "-s",
        "${LARK_MCP_APP_SECRET}",
        "-u",
        "${LARK_MCP_USER_ACCESS_TOKEN}"
      ]
    }
  }
}
